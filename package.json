{
  "name": "react-ai-translator",
  "version": "0.1.0",
  "type": "module",
  "description": "Drop-in floating AI translation button for any React app — runs 100% in-browser, no API key needed.",
  "keywords": ["react", "translation", "ai", "i18n", "xenova", "transformers", "nlp"],
  "license": "MIT",
  "main": "dist/react-ai-translator.cjs.js",
  "module": "dist/react-ai-translator.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/react-ai-translator.es.js",
      "require": "./dist/react-ai-translator.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:types": "tsc --project tsconfig.lib.json",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.1"
  }
}
